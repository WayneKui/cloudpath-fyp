# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Required ---

# Fernet key used to encrypt stored cloud credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CLOUDPATH_ENCRYPTION_KEY=

# PostgreSQL connection string. The password in CLOUDPATH_DB_DSN and
# POSTGRES_PASSWORD must be the same value — POSTGRES_PASSWORD sets the
# container's actual password, CLOUDPATH_DB_DSN is what the app connects
# with. If you change one, change the other to match.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
CLOUDPATH_DB_DSN=postgresql://cloudpath:changeme@localhost:15432/cloudpath
POSTGRES_PASSWORD=changeme

# Random string used to sign session cookies. Any long random value works.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# --- Optional (billing — only needed if using LemonSqueezy checkout) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Optional (have safe local-dev defaults if unset) ---

# Neo4j connection.
# Generate NEO4J_PASSWORD with: python -c "import secrets; print(secrets.token_urlsafe(24))"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Neo4j heap/pagecache sizing (used by docker-compose.postgres-only.yml).
# Defaults suit a small/free-tier host. Raise both if running on a host
# with more RAM available.
NEO4J_HEAP_SIZE=512m
NEO4J_PAGECACHE_SIZE=256m

# Your scanner AWS account ID (the account that assumes into customer
# accounts via sts:AssumeRole). Only needed if you're running your own
# scanner deployment rather than local dev against the default.
CLOUDPATH_SCANNER_AWS_ACCOUNT_ID=

# Set to "production" once deployed behind HTTPS — enables the Secure
# flag on session cookies. Leave unset for local HTTP development.
CLOUDPATH_ENV=

# --- AWS credentials for the scanner's OWN boto3 calls ---
# NOT read from this file. boto3 picks these up automatically from the
# standard AWS credential chain instead — the simplest option for local
# dev is exporting these two as regular environment variables (or setting
# them in a ~/.aws/credentials file); on EC2 use an IAM instance role and
# skip both entirely:
#   AWS_ACCESS_KEY_ID
#   AWS_SECRET_ACCESS_KEY
