# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Required ---

# Fernet key used to encrypt stored cloud credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CLOUDPATH_ENCRYPTION_KEY=

# PostgreSQL connection string.
CLOUDPATH_DB_DSN=postgresql://cloudpath:changeme@localhost:15432/cloudpath
POSTGRES_PASSWORD=changeme

# Random string used to sign session cookies. Any long random value works.
FLASK_SECRET_KEY=

# --- Optional (billing — only needed if using LemonSqueezy checkout) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Optional (have safe local-dev defaults if unset) ---

# Neo4j connection.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Your scanner AWS account ID (the account that assumes into customer
# accounts via sts:AssumeRole). Only needed if you're running your own
# scanner deployment rather than local dev against the default.
CLOUDPATH_SCANNER_AWS_ACCOUNT_ID=

# Set to "production" once deployed behind HTTPS — enables the Secure
# flag on session cookies. Leave unset for local HTTP development.
CLOUDPATH_ENV=

# --- AWS credentials for the scanner's OWN boto3 calls ---
# Not read from this file — use the standard AWS credential chain
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars, ~/.aws/credentials,
# or an IAM instance role if deployed on EC2).
